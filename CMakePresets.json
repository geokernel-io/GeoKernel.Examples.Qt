{
  "version": 3,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 23,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "windows-msvc",
      "displayName": "Windows MSVC",
      "generator": "Ninja Multi-Config",
      "binaryDir": "${sourceDir}/build/windows-msvc",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      },
      "cacheVariables": {
        "CMAKE_CONFIGURATION_TYPES": "Debug;Release;RelWithDebInfo",
        "GEOKERNEL_ROOT": "${sourceDir}/../GeoKernel"
      }
    },
    {
      "name": "linux",
      "displayName": "Linux",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/linux",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Linux"
      },
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "GEOKERNEL_ROOT": "${sourceDir}/../GeoKernel"
      }
    },
    {
      "name": "macos",
      "displayName": "macOS",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/macos",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Darwin"
      },
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "GEOKERNEL_ROOT": "${sourceDir}/../GeoKernel"
      }
    },
    {
      "hidden": true,
      "name": "Qt",
      "cacheVariables": {
        "CMAKE_PREFIX_PATH": "$env{QTDIR}"
      },
      "vendor": {
        "qt-project.org/Qt": {
          "checksum": "wVa86FgEkvdCTVp1/nxvrkaemJc="
        }
      }
    }
  ],
  "buildPresets": [
    {
      "name": "windows-msvc-debug",
      "configurePreset": "windows-msvc",
      "configuration": "Debug",
      "jobs": 8
    },
    {
      "name": "windows-msvc-release",
      "configurePreset": "windows-msvc",
      "configuration": "Release",
      "jobs": 8
    },
    {
      "name": "linux-release",
      "configurePreset": "linux"
    },
    {
      "name": "macos-release",
      "configurePreset": "macos"
    }
  ],
  "vendor": {
    "qt-project.org/Presets": {
      "checksum": "b0SUazXkMjxyD11eAOb6viSLmwM="
    }
  }
}